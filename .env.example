# Copy this file to .env and fill in the values before running docker compose up.

# PostgreSQL password for the postgres service
POSTGRES_PASSWORD=

# PostgreSQL connection string for the collector (must match the postgres service credentials)
DATABASE_URL=

# AbuseIPDB API key for IP reputation enrichment
# Get one at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# Telegram bot token for collector alerts
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for collector alerts
TELEGRAM_CHAT_ID=

# Collector log level
LOG_LEVEL=

# Name of the Cowrie Docker container (default: hollownet-cowrie)
DOCKER_CONTAINER_NAME=hollownet-cowrie
